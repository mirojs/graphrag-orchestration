    "helpTexts": {
        "promptTemplate":
            "覆盖根据问题和搜索结果生成回答时使用的提示词。若要在现有提示词后追加而非替换整个提示词，请在开头加上 '>>>'。",
        "temperature":
            "设置生成回答时向 LLM 发送请求的温度参数。较高的温度会产生更有创意的回答，但可能不够准确。",
        "seed": "设置 Seed 值以提高模型回答的可重复性。Seed 可以是任意整数。",
        "searchScore":
             "设置 Azure AI Search 返回搜索结果的最低分数。分数范围取决于您使用的是混合模式（默认）、仅向量还是仅文本。",
        "rerankerScore":
             "设置语义重排器返回搜索结果的最低分数。分数始终在 0 到 4 之间。分数越高，结果与问题的语义相关性越强。",
        "retrieveNumber":
             "设置从 Azure AI Search 检索的搜索结果数量。更多结果可能增加找到正确答案的概率，但也可能导致模型\u201c迷失在中间信息中\u201d。",
        "agenticReasoningEffort":
            "控制智能体在规划检索子查询时的推理力度。更高的力度可以提高召回率，但会增加延迟和 Token 消耗。",
        "includeCategory":
            "指定要包含在搜索结果中的类别。默认数据集中没有使用类别。",
         "excludeCategory":
            "指定要从搜索结果中排除的类别。默认数据集中没有使用类别。",
         "useSemanticReranker":
            "启用 Azure AI Search 语义排序器，该模型根据与用户查询的语义相似度对搜索结果重新排序。",
        "useQueryRewriting":
            "启用 Azure AI Search 查询重写功能，该功能会修改用户的查询以改善搜索结果。需要先启用语义排序器。",
        "reasoningEffort":
            "设置 LLM 的推理力度。较高的值会产生更多推理，但生成回答可能需要更长时间。默认值为中等。",
        "useSemanticCaptions":
             "向 LLM 发送语义摘要而非完整搜索结果。语义摘要是在语义排序过程中从搜索结果中提取的。",
        "suggestFollowupQuestions": "要求 LLM 根据用户的查询建议追问问题。",
        "textEmbeddings": "选中后，搜索将使用从提取的文本块生成的纯文本嵌入模型的嵌入向量。",
        "imageEmbeddings": "选中后，搜索将使用从提取的图像生成的多模态嵌入模型的嵌入向量。",
        "llmTextInputs": "选中后，搜索结果中的文本内容将作为上下文发送给 LLM。",
        "llmImageInputs": "选中后，搜索结果中的图像将作为上下文发送给 LLM。",
        "retrievalMode":
            "设置 Azure AI Search 查询的检索模式。\u201c向量 + 文本（混合）\u201d结合向量搜索和全文搜索，\u201c向量\u201d仅使用向量搜索，\u201c文本\u201d仅使用全文搜索。混合模式通常是最优选择。",
        "streamChat": "在生成回答时持续将响应流式传输到聊天界面。",
        "useOidSecurityFilter": "根据已认证用户的 OID 过滤搜索结果。",
        "useGroupsSecurityFilter": "根据已认证用户的用户组过滤搜索结果。",
        "useAgenticKnowledgeBase": "使用 Azure AI Search 的智能检索进行多查询规划。始终使用语义排序器。",
        "useWebSource": "使用网络搜索结果来补充已索引的数据集。",
        "useSharePointSource": "使用 SharePoint 内容来补充已索引的数据集。"
